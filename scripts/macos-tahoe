#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME="$(basename "$0")"
OS_NAME="macos-tahoe"

if [[ -n "${DOTFILES_DIR:-}" ]]; then
  DEFAULT_BASE="$DOTFILES_DIR/defaults/$OS_NAME"
else
  DEFAULT_BASE="$HOME/.dotfiles/defaults/$OS_NAME"
fi

usage() {
  cat <<USAGE
Usage:
  ./$SCRIPT_NAME dump [path]
  ./$SCRIPT_NAME load [path]

Defaults:
  path = DEFAULT_BASE/defaults/OS_NAME

Environment:
  DOTFILES_DIR  Base dotfiles directory. If unset, defaults to ~/.dotfiles
USAGE
}

require_macos() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "Error: $SCRIPT_NAME only supports macOS." >&2
    exit 1
  fi
}

restart_services() {
  local services=(
    Dock
    Finder
    SystemUIServer
    cfprefsd
    "System Settings"
  )

  for service in "${services[@]}"; do
    killall "$service" >/dev/null 2>&1 || true
  done
}

write_metadata() {
  local out_dir="$1"
  mkdir -p "$out_dir"
  cat > "$out_dir/_metadata.txt" <<META
script=$SCRIPT_NAME
profile=$OS_NAME
created_at_utc=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
hostname=$(scutil --get ComputerName 2>/dev/null || hostname)
macos_product_name=$(sw_vers -productName)
macos_product_version=$(sw_vers -productVersion)
macos_build_version=$(sw_vers -buildVersion)
user=$USER
META
}

write_readme() {
  local out_dir="$1"
  cat > "$out_dir/README.txt" <<README
This directory was generated by $SCRIPT_NAME.

Contents:
- domains/: plist exports created with 'defaults export'
- preferences/: direct copies of selected plist files
- byhost/: direct copies of selected ByHost plist files
- _metadata.txt: source machine metadata

Notes:
- Designed for same-version macOS restores.
- Some settings are host-specific, hardware-specific, or stored outside defaults/plists.
- Wallpaper and screensaver settings may still depend on referenced local file paths.
README
}

have_domain() {
  local domain="$1"
  defaults domains | tr ',' '\n' | sed 's/^ *//; s/ *$//' | grep -Fxq -- "$domain"
}

export_domain() {
  local domain="$1"
  local out_dir="$2/domains"
  mkdir -p "$out_dir"
  local file="$out_dir/${domain}.plist"

  if [[ "$domain" == "-g" ]]; then
    file="$out_dir/NSGlobalDomain.plist"
  fi

  if [[ "$domain" == "-g" ]]; then
    echo "Exporting NSGlobalDomain"
    defaults export -g "$file" >/dev/null 2>&1 || echo "Warning: failed to export NSGlobalDomain" >&2
    return
  fi

  if have_domain "$domain"; then
    echo "Exporting $domain"
    defaults export "$domain" "$file" >/dev/null 2>&1 || echo "Warning: failed to export $domain" >&2
  else
    echo "Skipping missing domain: $domain"
  fi
}

import_domain() {
  local domain="$1"
  local in_dir="$2/domains"
  local file="$in_dir/${domain}.plist"

  if [[ "$domain" == "-g" ]]; then
    file="$in_dir/NSGlobalDomain.plist"
  fi

  if [[ -f "$file" ]]; then
    if [[ "$domain" == "-g" ]]; then
      echo "Importing NSGlobalDomain"
      defaults import -g "$file"
    else
      echo "Importing $domain"
      defaults import "$domain" "$file"
    fi
  else
    echo "Skipping missing plist: $file"
  fi
}

copy_if_exists() {
  local src="$1"
  local dest_dir="$2"
  if [[ -e "$src" ]]; then
    mkdir -p "$dest_dir"
    cp -R "$src" "$dest_dir/"
    echo "Copied $(basename "$src")"
  else
    echo "Skipping missing file: $src"
  fi
}

dump_preferences_files() {
  local out_dir="$1"
  mkdir -p "$out_dir/preferences" "$out_dir/byhost"

  copy_if_exists "$HOME/Library/Preferences/com.apple.desktop.plist" "$out_dir/preferences"
  copy_if_exists "$HOME/Library/Preferences/com.apple.screensaver.plist" "$out_dir/preferences"
  copy_if_exists "$HOME/Library/Preferences/com.apple.systempreferences.plist" "$out_dir/preferences"
  copy_if_exists "$HOME/Library/Preferences/com.apple.finder.plist" "$out_dir/preferences"
  copy_if_exists "$HOME/Library/Preferences/com.apple.dock.plist" "$out_dir/preferences"
  copy_if_exists "$HOME/Library/Preferences/.GlobalPreferences.plist" "$out_dir/preferences"

  shopt -s nullglob
  local byhost_files=(
    "$HOME/Library/Preferences/ByHost/com.apple.screensaver."*.plist
    "$HOME/Library/Preferences/ByHost/com.apple.desktop."*.plist
    "$HOME/Library/Preferences/ByHost/com.apple.symbolichotkeys."*.plist
    "$HOME/Library/Preferences/ByHost/.GlobalPreferences."*.plist
  )
  for f in "${byhost_files[@]}"; do
    copy_if_exists "$f" "$out_dir/byhost"
  done
  shopt -u nullglob
}

restore_preferences_files() {
  local in_dir="$1"

  if [[ -d "$in_dir/preferences" ]]; then
    mkdir -p "$HOME/Library/Preferences"
    cp -R "$in_dir/preferences/." "$HOME/Library/Preferences/"
    echo "Restored preference plist files"
  fi

  if [[ -d "$in_dir/byhost" ]]; then
    mkdir -p "$HOME/Library/Preferences/ByHost"
    cp -R "$in_dir/byhost/." "$HOME/Library/Preferences/ByHost/"
    echo "Restored ByHost plist files"
  fi
}

dump_all() {
  local out_dir="$1"
  mkdir -p "$out_dir"
  write_metadata "$out_dir"
  write_readme "$out_dir"

  local domains=(
    -g
    com.apple.finder
    com.apple.dock
    com.apple.spaces
    com.apple.symbolichotkeys
    com.apple.universalaccess
    com.apple.AppleMultitouchTrackpad
    com.apple.driver.AppleBluetoothMultitouch.trackpad
    com.apple.driver.AppleBluetoothMultitouch.mouse
    com.apple.AppleMultitouchMouse
    com.apple.HIToolbox
    com.apple.screencapture
    com.apple.systempreferences
    com.apple.desktop
    com.apple.screensaver
    com.apple.controlcenter
    com.apple.menuextra.clock
    com.apple.menuextra.battery
    com.apple.WindowManager
  )

  for domain in "${domains[@]}"; do
    export_domain "$domain" "$out_dir"
  done

  dump_preferences_files "$out_dir"
  echo "Dump complete: $out_dir"
}

load_all() {
  local in_dir="$1"
  if [[ ! -d "$in_dir" ]]; then
    echo "Error: input directory not found: $in_dir" >&2
    exit 1
  fi

  local domains=(
    -g
    com.apple.finder
    com.apple.dock
    com.apple.spaces
    com.apple.symbolichotkeys
    com.apple.universalaccess
    com.apple.AppleMultitouchTrackpad
    com.apple.driver.AppleBluetoothMultitouch.trackpad
    com.apple.driver.AppleBluetoothMultitouch.mouse
    com.apple.AppleMultitouchMouse
    com.apple.HIToolbox
    com.apple.screencapture
    com.apple.systempreferences
    com.apple.desktop
    com.apple.screensaver
    com.apple.controlcenter
    com.apple.menuextra.clock
    com.apple.menuextra.battery
    com.apple.WindowManager
  )

  for domain in "${domains[@]}"; do
    import_domain "$domain" "$in_dir"
  done

  restore_preferences_files "$in_dir"
  restart_services
  echo "Load complete: $in_dir"
}

main() {
  require_macos

  local cmd="${1:-}"
  local path="${2:-$DEFAULT_BASE}"

  case "$cmd" in
    dump)
      dump_all "$path"
      ;;
    load)
      load_all "$path"
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      echo "Error: unknown command '$cmd'" >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
