<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>KeepAlive</key>
	<false/>
	<key>Label</key>
	<string>com.dmarksys.emacsd.git-tty</string>
	<key>Nice</key>
	<integer>1</integer>
	<key>Program</key>
	<string>/bin/zsh</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/zsh</string>
		<string>-lc</string>
		<string>emacsd git-tty</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardErrorPath</key>
	<string>/tmp/com.dmarksys.emacsd.git-tty.err</string>
	<key>StandardOutPath</key>
	<string>/tmp/com.dmarksys.emacsd.git-tty.out</string>
</dict>
</plist>
