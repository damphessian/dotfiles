#!/usr/bin/env bash

#
# e
#
# Usage:
#
#   e [ARGS]
#
# Available Options:
#
#   -h      -- Usage instructions
#

usage() {
  grep '^#' <"$0" | tail -n +2 | cut -c 3-
}

if [[ -z "${DOTFILES_DIR}" ]]; then
  echo "Error: DOTFILES_DIR not set"
  exit 1
fi

if [[ $# == 0 ]]; then
  ARGS="$(
    fzf \
      --multi \
      --tiebreak=index \
      --layout=reverse \
      --preview-window='right,75%,~1' \
      --preview="bat --color=always {}"
    )"
  if [[ -z "$ARGS" ]]; then
    exit 0
  fi
else
  ARGS=${1:-.}
fi

open -a "${DOTFILES_DIR}"/scripts/Emacs.app ${ARGS} &

# emacsclient \
#     --alternate-editor="" \
#     --no-window-system \
#     --quiet \
#     --suppress-output \
#     $ARGS
#
# reset
